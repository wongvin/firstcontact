<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Bundle identity: values the auto-generated Info.plist used to synthesize from build
	     settings. Now that GENERATE_INFOPLIST_FILE is off, they are supplied here via $(…). -->
	<key>CFBundleDevelopmentRegion</key>
	<string>$(DEVELOPMENT_LANGUAGE)</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>$(PRODUCT_NAME)</string>
	<key>CFBundlePackageType</key>
	<string>$(PRODUCT_BUNDLE_PACKAGE_TYPE)</string>
	<key>CFBundleShortVersionString</key>
	<string>$(MARKETING_VERSION)</string>
	<key>CFBundleVersion</key>
	<string>$(CURRENT_PROJECT_VERSION)</string>

	<!-- Local device-to-device keyword sync over Multipeer Connectivity. iOS 14+ requires a
	     local-network usage string plus the Bonjour service types the app browses/advertises;
	     Bluetooth is one of MPC's transports. Without these the OS silently blocks discovery. -->
	<key>NSLocalNetworkUsageDescription</key>
	<string>Syncs your keyword filters with your other nearby devices.</string>
	<key>NSBluetoothAlwaysUsageDescription</key>
	<string>Syncs your keyword filters with your other nearby devices.</string>
	<key>NSBonjourServices</key>
	<array>
		<string>_fc-sync._tcp</string>
		<string>_fc-sync._udp</string>
	</array>

	<!-- Migrated from the former INFOPLIST_KEY_* build settings (written out as real keys; the
	     two *_Generation directives are expanded into what they used to synthesize). -->
	<key>UIApplicationSceneManifest</key>
	<dict>
		<key>UIApplicationSupportsMultipleScenes</key>
		<true/>
	</dict>
	<key>UIApplicationSupportsIndirectInputEvents</key>
	<true/>
	<key>UILaunchScreen</key>
	<dict/>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>UISupportedInterfaceOrientations~ipad</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
</dict>
</plist>
